@{
    ViewData["Title"] = "Page Not Found";
    ViewData["LockScroll"] = true;
}

<!-- Include the Share Tech Mono font from Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">

<!-- Mobile Menu Button -->
<button class="mobile-menu-btn d-lg-none">
    <i class="fas fa-bars"></i>
</button>

<div class="glass-container">
    <main class="main-content">
        <div class="content-header welcome-section" style="padding: 5rem 2rem; margin-top: 10vh;">
            <!-- Title -->
            <h1 style="font-family: 'Share Tech Mono', monospace; font-size: 8rem; color: var(--secondary); margin-bottom: 0; line-height: 1;">404</h1>

            <h2>Looks like you're lost!</h2>

            <!-- Error Message -->
            <p class="mb-4" style="font-size: 1.1rem;">
                The page you are looking for has gone missing. <br />
                Don't worry, even a Lost & Found system loses things sometimes.
            </p>

            <!-- Navigate to the Dashboard -->
            <a href="@Url.Action("Index", "Home")" class="btn-primary" style="display: inline-block; padding: 1rem 2rem;">
                <i class="fa-solid fa-house me-2"></i> Return to Dashboard
            </a>

        </div>
    </main>
</div>