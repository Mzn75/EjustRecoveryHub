@model EjustRecoveryHub.Models.ItemViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Report Found Items";

    // 1. Read the messages
    var successMessage = TempData["SuccessMessage"] as string;
    var duplicateMessage = TempData["DuplicateMessage"] as string;

    var isDuplicate = ViewBag.Duplicate == true || !string.IsNullOrEmpty(duplicateMessage);

    // 2. NUKE THEM! Force the server to forget them immediately
    TempData.Remove("SuccessMessage");
    TempData.Remove("DuplicateMessage");
}


<!-- Mobile Menu Button -->
<button class="mobile-menu-btn d-lg-none">
    <i class="fas fa-bars"></i>
</button>

<div class="glass-container">
    <main class="main-content">
        <div class="content-header welcome-section">
            <h2>Report Found Items</h2>
            <p>Help a fellow student by registering what you found.</p>
        </div>

        <div class="search-wrapper">
            <form id="reportItemForm" asp-controller="Items" asp-action="SubmitFoundItem" method="post" enctype="multipart/form-data" class="custom-search-form form-stacked">

                <!-- Generating Hidden Security Token -->
                @Html.AntiForgeryToken()

                <!-- Item Category -->
                <div class="custom-dropdown-wrapper mb-4">

                    <div class="search-input-group custom-dropdown-trigger" id="customDropdownTrigger">
                        <i class="fa-solid fa-layer-group search-icon"></i>
                        <span class="dropdown-selected-text">  Choose Item Type </span>
                        <i class="fa-solid fa-chevron-down dropdown-arrow"></i>
                    </div>

                    <div class="custom-dropdown-menu" id="customDropdownMenu">
                        <div class="custom-option" data-value="id">ID Card</div>
                        <div class="custom-option" data-value="wallet">Wallet</div>
                        <div class="custom-option" data-value="device">Electronic Device</div>
                        <div class="custom-option" data-value="jewelry">Jewelry</div>
                        <div class="custom-option" data-value="notebook">Notebook</div>
                    </div>

                    <select id="itemCategory" name="Category" required style="display: none;">
                        <option value="" disabled selected>  Choose Item Type  </option>
                        <option value="id">ID Card</option>
                        <option value="wallet">Wallet</option>
                        <option value="device">Electronic Device</option>
                        <option value="jewelry">Jewelry</option>
                        <option value="notebook">Notebook</option>
                    </select>
                </div>

                <!-- Dynamic Fields Container -->
                <div id="dynamicFieldsContainer" style="display: none;">

                    <!-- ID Card Fields -->
                    <div id="fields-id" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-id-card search-icon"></i>
                            <input type="text" name="IdName" class="search-input dynamic-input" placeholder="Name written on the ID" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-hashtag search-icon"></i>
                            <input type="text" name="IdNumber" class="search-input dynamic-input" placeholder="ID Number / Student ID" />
                        </div>
                    </div>

                    <!-- Wallet Fields -->
                    <div id="fields-wallet" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-palette search-icon"></i>
                            <input type="text" name="WalletColor" class="search-input dynamic-input" placeholder="Color (e.g., Black, Brown)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-brands fa-cc-visa search-icon"></i>
                            <input type="text" name="WalletBrandOrMaterial" class="search-input dynamic-input" placeholder="Brand or Material (e.g., Leather)" />
                        </div>
                    </div>

                    <!-- Device Fields -->
                    <div id="fields-device" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-mobile-screen search-icon"></i>
                            <input type="text" name="DeviceBrand" class="search-input dynamic-input" placeholder="Brand (e.g., Samsung, Apple)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-microchip search-icon"></i>
                            <input type="text" name="DeviceModel" class="search-input dynamic-input" placeholder="Model (e.g., iPhone 15)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-align-left search-icon"></i>
                            <input type="text" name="DeviceDescription" class="search-input dynamic-input" placeholder="Description (e.g., Cover Shape, Wallpaper)" />
                        </div>
                    </div>

                    <!-- Jewelry Fields -->
                    <div id="fields-jewelry" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-ring search-icon"></i>
                            <input type="text" name="JewelryType" class="search-input dynamic-input" placeholder="Type (e.g., Ring, Necklace)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-gem search-icon"></i>
                            <input type="text" name="JewelryMaterial" class="search-input dynamic-input" placeholder="Material (e.g., Gold, Silver)" />
                        </div>
                    </div>

                    <!-- Notebook Fields -->
                    <div id="fields-notebook" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-book search-icon"></i>
                            <input type="text" name="NotebookColor" class="search-input dynamic-input" placeholder="Color (e.g., Red, Blue)" />
                        </div>
                    </div>

                    <!-- Photo Upload -->
                    <hr class="form-divider" />
                    <div class="custom-file-upload mb-4">
                        <input type="file" id="ItemPhoto" name="ItemPhoto" class="d-none" accept="image/*" onchange="previewImage(this)" />
                        <label for="ItemPhoto" class="upload-glass-btn" id="uploadLabel">
                            <img id="imagePreview" src="" alt="Item Preview" style="display: none; width: 100%; max-height: 250px; object-fit: cover; border-radius: 8px;" />
                            <div id="uploadTextContainer">
                                <i class="fa-solid fa-camera me-2"></i>
                                <span>Upload Item Photo (Optional)</span>
                            </div>
                        </label>
                    </div>

                    <!-- Location Found -->
                    <div class="search-input-group mb-3">
                        <i class="fa-solid fa-location-dot search-icon"></i>
                        <input type="text" name="LocationFound" class="search-input" placeholder="Exact location you found it" required />
                    </div>

                    <!-- Item Location -->
                    <div class="search-input-group mb-4">
                        <i class="fa-solid fa-building-shield search-icon"></i>
                        <input type="text" name="ItemLocation" class="search-input" placeholder="Where is the item now ?" required />
                    </div>

                    <!-- Contact Information -->
                    <div class="search-input-group mb-4">
                        <i class="fa-solid fa-phone search-icon"></i>
                        <input type="tel" name="ContactNumber" class="search-input" placeholder="Your Phone Number" inputmode="numeric" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required />
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="search-btn w-100">
                        <i class="fa-solid fa-hand-holding-heart me-2"></i> Submit Item Report
                    </button>
                </div>
            </form>
        </div>
        <div class="form-divider"></div>

        <!-- 4. The Global Live Feed -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-5 mt-5" style="color: var(--primary); font-weight: 700;">Items You Recently Found</h3>

            <form method="get" asp-action="FoundItems" asp-controller="Items" class="m-0">
                <select name="filter" onchange="this.form.submit()" class="shadow-sm"
                        style="appearance: none; -webkit-appearance: none; background-color: white; border: 1px solid rgba(0, 0, 0, 0.1); border-radius: 8px; color: #555; padding: 0.4rem 2rem 0.4rem 1rem; font-size: 0.85rem; font-weight: 500; cursor: pointer; outline: none; background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23333%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.7rem top 50%; background-size: 0.6rem auto;">

                    @if (ViewBag.CurrentFilter == "active")
                    {
                        <option value="recent">Recently Reported</option>
                        <option value="active" selected>Status: Active First</option>
                    }
                    else
                    {
                        <option value="recent" selected>Recently Reported</option>
                        <option value="active">Status: Active First</option>
                    }
                </select>
            </form>
        </div>

        @if (ViewBag.RecentItems != null && ViewBag.RecentItems.Count > 0)
        {
            <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
                @foreach (var item in ViewBag.RecentItems)
                {
                    <div class="element-card freeze-hover" style="display: flex; flex-direction: row; align-items: center; padding: 1rem; min-height: 100px;">
               
                        <!-- Left Side: Image -->
                        <div style="width: 80px; height: 80px; flex-shrink: 0; border-radius: 12px; overflow: hidden; margin-right: 1.5rem;">
                            @if (!string.IsNullOrEmpty(item.PhotoPath))
                            {
                                <img src="@item.PhotoPath" alt="Item" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                // 1. Figure out which icon to use based on the item type
                                string iconClass = "fa-box"; // Fallback default
                                switch (item)
                                {
                                    case EjustRecoveryHub.Models.IdItem:
                                        iconClass = "fa-id-card";
                                        break;
                                    case EjustRecoveryHub.Models.WalletItem:
                                        iconClass = "fa-wallet"; // Using standard wallet icon
                                        break;
                                    case EjustRecoveryHub.Models.DeviceItem:
                                        iconClass = "fa-mobile-screen";
                                        break;
                                    case EjustRecoveryHub.Models.JewelryItem:
                                        iconClass = "fa-ring";
                                        break;
                                    case EjustRecoveryHub.Models.NotebookItem:
                                        iconClass = "fa-book";
                                        break;
                                }

                                // 2. Render the specific icon with a nice soft background
                                <div class="d-flex align-items-center justify-content-center" style="width: 100%; height: 100%; background: #f8f9fa; border: 1px solid #e9ecef;">
                                    <i class="fa-solid @iconClass fa-2x" style="color: var(--secondary);"></i>
                                </div>
                            }
                        </div>

                        <!-- Right Side: Details -->
                        <div style="flex-grow: 1;">
                            <h4 class="mb-1" style="color: var(--primary); font-size: 1.2rem; font-weight: 700;">
                                <!-- POLYMORPHIC FIX: Switching on the Object Type -->
                                @switch (item)
                                {
                                    case EjustRecoveryHub.Models.IdItem:
                                        @:ID Card
                                        break;
                                    case EjustRecoveryHub.Models.WalletItem:
                                        @:Wallet
                                        break;
                                    case EjustRecoveryHub.Models.DeviceItem:
                                        @:Device
                                        break;
                                    case EjustRecoveryHub.Models.JewelryItem:
                                        @:Jewelry
                                        break;
                                    case EjustRecoveryHub.Models.NotebookItem:
                                        @:Notebook
                                        break;
                                    default:
                                        @:Other
                                        break;
                                }
                            </h4>
                            <div style="color: #5a6c7d; font-size: 0.95rem;">
                                <!-- POLYMORPHIC FIX: Using the mapped typed variables (idCard, wallet, etc.) -->
                                @switch (item)
                                {
                                    case EjustRecoveryHub.Models.IdItem idCard:
                                        <strong>Name & ID:</strong>
                                        @idCard.IdName
                                        @:/ @idCard.IdNumber
                                        break;
                                    case EjustRecoveryHub.Models.WalletItem wallet:
                                        <strong>Description:</strong>
                                        @wallet.WalletColor
                                        @: @wallet.WalletBrandOrMaterial
                                        break;
                                    case EjustRecoveryHub.Models.DeviceItem device:
                                        <strong>Brand & Model:</strong>
                                        @device.DeviceBrand
                                        @: @device.DeviceModel
                                        break;
                                    case EjustRecoveryHub.Models.JewelryItem jewelry:
                                        <strong>Description:</strong>
                                        @jewelry.JewelryMaterial
                                        @: @jewelry.JewelryType
                                        break;
                                    case EjustRecoveryHub.Models.NotebookItem notebook:
                                        <strong>Color:</strong>
                                        @notebook.NotebookColor
                                        break;
                                    default:
                                        @:Other
                                        break;
                                }
                                <br />
                                <strong>Found at:</strong> @item.LocationFound
                            </div>
                        </div>

                        <!-- Far Right: Status Badge & Dropdown -->
                        <div style="padding-left: 1rem; display: flex; align-items: center; gap: 0.75rem;">

                            @if (ViewBag.MyReportedIds != null && ((List<int>)ViewBag.MyReportedIds).Contains(item.Id))
                            {
                                string displayText = item.Status == "Returned" ? "Returned" : "Active";
                                string statusColor = item.Status == "Returned" ? "var(--secondary)" : "var(--accent)";

                                <form method="post" asp-action="UpdateStatus" asp-controller="Items" id="statusForm-@item.Id" style="margin: 0; position: relative;">

                                    <!-- Generating Hidden Security Token -->
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@item.Id" />

                                    <div id="trigger-@item.Id" class="customDropdownTrigger" onclick="toggleStatusMenu(event, @item.Id)" style="border-radius: 12px; border: 1px solid rgba(0,0,0,0.1); padding: 0.5rem 1rem; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background: white; min-width: 170px;">
                                        <span style="color: @statusColor; font-size: 0.9rem; font-weight: 600;">@displayText</span>
                                        <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem; color: @statusColor;"></i>
                                    </div>

                                    <div class="custom-dropdown-menu" id="statusMenu-@item.Id">
                                        <div class="custom-option" onclick="submitNewStatus(@item.Id, 'Active')">Active</div>
                                        <div class="custom-option" onclick="submitNewStatus(@item.Id, 'Returned')">Returned</div>
                                    </div>

                                    <select id="hiddenSelect-@item.Id" name="newStatus" required style="display: none;">
                                        @if (item.Status == "Returned")
                                        {
                                            <option value="Active">Active</option>
                                            <option value="Returned" selected>Returned</option>
                                        }
                                        else
                                        {
                                            <option value="Active" selected>Active</option>
                                            <option value="Returned">Returned</option>
                                        }
                                    </select>
                                </form>

                                <script> document.getElementById('statusForm-@item.Id').closest('.element-card').style.overflow = 'visible'; </script>
                            }

                            <span class="card-badge badge-found" style="position: static; display: inline-block; white-space: nowrap;">
                                Reported: @item.DateReported.ToString("MMM dd, yyyy")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="content-header text-center py-5" style="background: rgba(255,255,255,0.6); box-shadow: none; border: 2px dashed rgba(0,0,0,0.1);">
                <i class="fa-solid fa-magnifying-glass fa-3x mb-3" style="color: var(--secondary);"></i>
                <p class="mb-0" style="color: var(--dark); font-weight: 500;">No items have been reported recently.</p>
            </div>
        }
    </main>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
    if (typeof Swal === 'undefined') {
    console.error('SweetAlert2 not loaded');
    return;
    }

    @if (!string.IsNullOrEmpty(duplicateMessage))
    {
        <text>
            Swal.fire({
            title: 'Duplicated Report',
            text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(duplicateMessage)),
            icon: 'warning',
            showCancelButton: true,
            showConfirmButton: false,
            cancelButtonText: 'Go Back',
            buttonsStyling: false,
            customClass: {
            popup: 'swal-glass-popup',
            title: 'swal-glass-title',
            htmlContainer: 'swal-glass-text',
            confirmButton: 'swal-glass-confirm',
            cancelButton: 'swal-glass-cancel'
            }
            });
        </text>
    }

    var form = document.getElementById('reportItemForm');
    if (form) {
    form.addEventListener('submit', function (e) {
    e.preventDefault();
    Swal.fire({
    title: 'Report this item?',
    text: "Are you sure all the details and photos are correct?",
    icon: 'question',
    showCancelButton: true,
    confirmButtonText: 'Yes, submit it!',
    cancelButtonText: 'Go back',
    buttonsStyling: false,
    reverseButtons: true,
    customClass: {
    popup: 'swal-glass-popup',
    title: 'swal-glass-title',
    htmlContainer: 'swal-glass-text',
    confirmButton: 'swal-glass-confirm',
    cancelButton: 'swal-glass-cancel'
    }
    }).then((result) => {
    if (result.isConfirmed) form.submit();
    });
    });
    } else {
    console.warn('reportItemForm not found');
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <text>
            Swal.fire({
            title: 'Success!',
            text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMessage)),
            icon: 'success',
            confirmButtonText: 'Great!',
            buttonsStyling: false,
            customClass: {
            popup: 'swal-glass-popup',
            title: 'swal-glass-title',
            htmlContainer: 'swal-glass-text',
            confirmButton: 'swal-glass-confirm'
            }
            });
        </text>
    }
    });
</script>
<script>
    function toggleStatusMenu(e, id) {
    e.stopPropagation();

    var menu = document.getElementById('statusMenu-' + id);
    var trigger = document.getElementById('trigger-' + id);

    document.querySelectorAll('.custom-dropdown-menu[id^="statusMenu-"]').forEach(m => m.classList.remove('active'));
    document.querySelectorAll('div[id^="trigger-"]').forEach(t => t.classList.remove('open'));

    menu.classList.toggle('active');
    trigger.classList.toggle('open');
    }

    function submitNewStatus(id, statusValue) {
    document.getElementById('hiddenSelect-' + id).value = statusValue;
    document.getElementById('statusForm-' + id).submit();
    }

    document.addEventListener('click', function (e) {
    document.querySelectorAll('.custom-dropdown-menu[id^="statusMenu-"]').forEach(m => m.classList.remove('active'));
    document.querySelectorAll('div[id^="trigger-"]').forEach(t => t.classList.remove('open'));
    });
</script>