@model EjustRecoveryHub.Models.ItemViewModel
@{
    ViewData["Title"] = "Report Found Items";

    // 1. Read the messages
    var successMessage = TempData["SuccessMessage"] as string;
    var duplicateMessage = TempData["DuplicateMessage"] as string;

    var isDuplicate = ViewBag.Duplicate == true || !string.IsNullOrEmpty(duplicateMessage);

    var egyptTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Egypt Standard Time");

    // 2. NUKE THEM! Force the server to forget them immediately
    TempData.Remove("SuccessMessage");
    TempData.Remove("DuplicateMessage");
}

<!-- Mobile Menu Button -->
<button class="mobile-menu-btn d-lg-none">
    <i class="fas fa-bars"></i>
</button>

<div class="glass-container">
    <main class="main-content">
        <div class="content-header welcome-section">
            <h2>Report Found Items</h2>
            <p>Help a fellow student by registering what you found.</p>
        </div>

        <div class="search-wrapper">
            <form id="reportItemForm" asp-controller="Items" asp-action="SubmitFoundItem" method="post" enctype="multipart/form-data" class="custom-search-form form-stacked">

                <!-- Generating Hidden Security Token -->
                @Html.AntiForgeryToken()

                <!-- Accessible Custom Dropdown -->
                <div class="custom-dropdown-wrapper mb-4">

                    <!-- Hidden native select for the actual form submission -->
                    <select id="itemCategory" name="Category" required style="display: none;">
                        <option value="" disabled selected>Choose Item Type</option>
                        <option value="id">ID Card</option>
                        <option value="wallet">Wallet</option>
                        <option value="device">Electronic Device</option>
                        <option value="jewelry">Jewelry</option>
                        <option value="notebook">Notebook</option>
                    </select>

                    <!-- The Custom Trigger (Focusable) -->
                    <div class="search-input-group custom-dropdown-trigger" id="customDropdownTrigger"
                         tabindex="0" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-controls="customDropdownMenu">
                        <i class="fa-solid fa-layer-group search-icon"></i>
                        <span class="dropdown-selected-text"> Choose Item Type </span>
                        <i class="fa-solid fa-chevron-down dropdown-arrow"></i>
                    </div>

                    <!-- The Custom Menu -->
                    <div class="custom-dropdown-menu" id="customDropdownMenu" role="listbox">
                        <div class="custom-option" role="option" tabindex="-1" data-value="id">ID Card</div>
                        <div class="custom-option" role="option" tabindex="-1" data-value="wallet">Wallet</div>
                        <div class="custom-option" role="option" tabindex="-1" data-value="device">Electronic Device</div>
                        <div class="custom-option" role="option" tabindex="-1" data-value="jewelry">Accessories</div>
                        <div class="custom-option" role="option" tabindex="-1" data-value="notebook">Notebook</div>
                    </div>
                </div>

                <!-- Dynamic Fields Container -->
                <div id="dynamicFieldsContainer" style="display: none;">

                    <!-- ID Card Fields -->
                    <div id="fields-id" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-id-card search-icon"></i>
                            <input type="text" name="IdName" class="search-input dynamic-input" placeholder="Name written on the ID" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-hashtag search-icon"></i>
                            <input type="text" name="IdNumber" class="search-input dynamic-input" placeholder="ID Number / Student ID" />
                        </div>
                    </div>

                    <!-- Wallet Fields -->
                    <div id="fields-wallet" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-palette search-icon"></i>
                            <input type="text" name="WalletColor" class="search-input dynamic-input" placeholder="Color (e.g., Black, Brown)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-brands fa-cc-visa search-icon"></i>
                            <input type="text" name="WalletBrandOrMaterial" class="search-input dynamic-input" placeholder="Brand or Material (e.g., Leather)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-align-left search-icon"></i>
                            <input type="text" name="WalletDescription" class="search-input dynamic-input" placeholder="Description (e.g., Custom Design, Special Mark, Color)" />
                        </div>
                    </div>

                    <!-- Device Fields -->
                    <div id="fields-device" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-mobile-screen search-icon"></i>
                            <input type="text" name="DeviceBrand" class="search-input dynamic-input" placeholder="Brand (e.g., Samsung, Apple)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-microchip search-icon"></i>
                            <input type="text" name="DeviceModel" class="search-input dynamic-input" placeholder="Model (e.g., iPhone 15)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-align-left search-icon"></i>
                            <input type="text" name="DeviceDescription" class="search-input dynamic-input" placeholder="Description (e.g., Cover Shape, Wallpaper)" />
                        </div>
                    </div>

                    <!-- Jewelry Fields -->
                    <div id="fields-jewelry" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-ring search-icon"></i>
                            <input type="text" name="JewelryType" class="search-input dynamic-input" placeholder="Type (e.g., Ring, Necklace, Watch)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-gem search-icon"></i>
                            <input type="text" name="JewelryMaterial" class="search-input dynamic-input" placeholder="Material (e.g., Gold, Silver)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-align-left search-icon"></i>
                            <input type="text" name="JewelryDescription" class="search-input dynamic-input" placeholder="Description (e.g., Engraving, Gemstone, Color)" />
                        </div>
                    </div>

                    <!-- Notebook Fields -->
                    <div id="fields-notebook" class="dynamic-group">
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-book search-icon"></i>
                            <input type="text" name="NotebookColor" class="search-input dynamic-input" placeholder="Color (e.g., Red, Blue)" />
                        </div>
                        <div class="search-input-group mb-3">
                            <i class="fa-solid fa-align-left search-icon"></i>
                            <input type="text" name="NotebookDescription" class="search-input dynamic-input" placeholder="Description (e.g., Name, Shape, Special Marks)" />
                        </div>
                    </div>

                    <!-- Photo Upload -->
                    <hr class="form-divider" />
                    <div class="custom-file-upload mb-4">
                        <input type="file" id="ItemPhoto" name="ItemPhoto" class="d-none" accept="image/*" onchange="previewImage(this)" />
                        <span asp-validation-for="ItemPhoto" class="text-danger" style="color: red;"></span>
                        <label for="ItemPhoto" class="upload-glass-btn" id="uploadLabel">
                            <img id="imagePreview" src="" alt="Item Preview" class="image-preview-thumbnail" style="display: none;" />
                            <div id="uploadTextContainer">
                                <i class="fa-solid fa-camera me-2"></i>
                                <span>Upload Item Photo (Optional)</span>
                            </div>
                        </label>
                    </div>

                    <!-- Location Found -->
                    <div class="search-input-group mb-3">
                        <i class="fa-solid fa-location-dot search-icon"></i>
                        <input type="text" name="LocationFound" class="search-input" placeholder="Exact location you found it" required />
                    </div>

                    <!-- Item Location -->
                    <div class="search-input-group mb-4">
                        <i class="fa-solid fa-building-shield search-icon"></i>
                        <input type="text" name="ItemLocation" class="search-input" placeholder="Where is the item now ?" required />
                    </div>

                    <!-- Contact Information -->
                    <hr class="form-divider" />
                    <div class="mb-4">
                        <label class="info-label mb-3 d-block" style="color: var(--dark); font-weight: 600;">
                            How should the owner contact you?
                        </label>

                        <!-- The Toggle Switches -->
                        <div class="d-flex gap-4 mb-3 px-2">
                            <div class="form-check custom-radio">
                                <input class="form-check-input" type="radio" name="contactChoice" id="choicePhone" value="phone" checked style="cursor: pointer;">
                                <label class="form-check-label" for="choicePhone" style="cursor: pointer; color: var(--dark);">
                                    Phone Number
                                </label>
                            </div>
                            <div class="form-check custom-radio">
                                <input class="form-check-input" type="radio" name="contactChoice" id="choiceEmail" value="email" style="cursor: pointer;">
                                <label class="form-check-label" for="choiceEmail" style="cursor: pointer; color: var(--dark);">
                                    Email Address
                                </label>
                            </div>
                        </div>

                        <!-- Phone Input (Visible by default) -->
                        <div id="phoneInputContainer" class="search-input-group mb-4">
                            <i class="fa-solid fa-phone search-icon"></i>
                            <input type="tel" id="ContactPhone" name="ContactNumber" class="search-input" placeholder="Phone Number (e.g., 01xxxxxxxxx)" inputmode="numeric" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                        </div>

                        <!-- Email Input (Hidden by default) -->
                        <div id="emailInputContainer" class="search-input-group mb-4" style="display: none;">
                            <i class="fa-solid fa-envelope search-icon"></i>
                            <input type="email" id="ContactEmail" name="ContactEmail" class="search-input" placeholder="Email Address (e.g., student@ejust.edu.eg)" />
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="search-btn w-100">
                        <i class="fa-solid fa-hand-holding-heart me-2"></i> Submit Item Report
                    </button>
                </div>
            </form>
        </div>
        <div class="form-divider"></div>

        <!-- 4. The Global Live Feed -->
        <div class="mb-4">
            <h3 class="mb-4 mt-5 feed-title">Items You Recently Found</h3>
        </div>

        @if (ViewBag.RecentItems != null && ViewBag.RecentItems.Count > 0)
        {
            
            <div class="feed-list">
                @foreach (var item in ViewBag.RecentItems)
                {
                    var localTime = TimeZoneInfo.ConvertTimeFromUtc(item.DateReported, egyptTimeZone);
                    <div class="element-card freeze-hover feed-card-horizontal">

                        <!-- Left Side: Image -->
                        <div class="item-thumbnail">
                            @if (!string.IsNullOrEmpty(item.PhotoPath))
                            {
                                <img src="@item.PhotoPath" alt="Item" class="item-thumbnail-img" />
                            }
                            else
                            {
                                // 1. Figure out which icon to use based on the item type
                                string iconClass = "fa-box"; // Fallback default
                                switch (item)
                                {
                                    case EjustRecoveryHub.Models.IdItem:
                                        iconClass = "fa-id-card";
                                        break;
                                    case EjustRecoveryHub.Models.WalletItem:
                                        iconClass = "fa-wallet";
                                        break;
                                    case EjustRecoveryHub.Models.DeviceItem:
                                        iconClass = "fa-mobile-screen";
                                        break;
                                    case EjustRecoveryHub.Models.JewelryItem:
                                        iconClass = "fa-ring";
                                        break;
                                    case EjustRecoveryHub.Models.NotebookItem:
                                        iconClass = "fa-book";
                                        break;
                                }

                                <!-- 2. Render the specific icon -->
                                <div class="d-flex align-items-center justify-content-center item-thumbnail-fallback">
                                    <i class="fa-solid @iconClass fa-2x" style="color: var(--secondary);"></i>
                                </div>
                            }
                        </div>

                        <!-- Right Side: Details -->
                        <div class="item-details">
                            <h4 class="mb-1 item-title">
                                <!-- POLYMORPHIC FIX: Switching on the Object Type -->
                                @switch (item)
                                {
                                    case EjustRecoveryHub.Models.IdItem:
                                        @:ID Card
                                        break;
                                    case EjustRecoveryHub.Models.WalletItem:
                                        @:Wallet
                                        break;
                                    case EjustRecoveryHub.Models.DeviceItem:
                                        @:Device
                                        break;
                                    case EjustRecoveryHub.Models.JewelryItem:
                                        @:Jewelry
                                        break;
                                    case EjustRecoveryHub.Models.NotebookItem:
                                        @:Notebook
                                        break;
                                    default:
                                        @:Other
                                        break;
                                }
                            </h4>
                            <div class="item-description">
                                <!-- POLYMORPHIC FIX: Using the mapped typed variables (idCard, wallet, etc.) -->
                                @switch (item)
                                {
                                    case EjustRecoveryHub.Models.IdItem idCard:
                                        <strong>Name & ID:</strong>
                                        @idCard.IdName
                                        @:/ @idCard.IdNumber
                                        break;
                                    case EjustRecoveryHub.Models.WalletItem wallet:
                                        <strong>Description:</strong>
                                        @wallet.WalletColor
                                        @: @wallet.WalletBrandOrMaterial
                                        break;
                                    case EjustRecoveryHub.Models.DeviceItem device:
                                        <strong>Brand & Model:</strong>
                                        @device.DeviceBrand
                                        @: @device.DeviceModel
                                        break;
                                    case EjustRecoveryHub.Models.JewelryItem jewelry:
                                        <strong>Description:</strong>
                                        @jewelry.JewelryMaterial
                                        @: @jewelry.JewelryType
                                        break;
                                    case EjustRecoveryHub.Models.NotebookItem notebook:
                                        <strong>Color:</strong>
                                        @notebook.NotebookColor
                                        break;
                                    default:
                                        @:Other
                                        break;
                                }
                                <br />
                                <strong>Found at:</strong> @item.LocationFound
                            </div>
                        </div>

                        <!-- Far Right: Status Dropdown -->
                        <div class="item-actions">
                            @if (ViewBag.MyReportedIds != null && ((List<int>)ViewBag.MyReportedIds).Contains(item.Id))
                            {
                                string statusColor = item.Status == "Returned" ? "var(--secondary)" : "var(--accent)";

                                <form method="post" asp-action="UpdateStatus" asp-controller="Items" id="statusForm-@item.Id" class="status-form" style="max-width: 120px;">
                                    <!-- Generating Hidden Security Token -->
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />

                                    <!-- Native Auto-Submitting Select -->
                                    <select name="newStatus" class="native-status-select" style="color: @statusColor;" onchange="this.form.submit()">
                                        @if (item.Status == "Returned")
                                        {
                                            <option value="Active">Active</option>
                                            <option value="Returned" selected>Returned</option>
                                        }
                                        else
                                        {
                                            <option value="Active" selected>Active</option>
                                            <option value="Returned">Returned</option>
                                        }
                                    </select>
                                </form>
                            }

                            <span class="card-badge badge-found badge-static">
                                Reported: @localTime.ToString("MMM dd yyyy 'At' hh:mm tt")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="content-header text-center py-5 empty-state-card">
                <i class="fa-solid fa-magnifying-glass fa-3x mb-3 empty-state-icon"></i>
                <p class="mb-0 empty-state-text">No items have been reported recently.</p>
            </div>
        }
    </main>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof Swal === 'undefined') {
            console.error('SweetAlert2 not loaded');
            return;
        }

        // Duplicate Report Check
        @if (!string.IsNullOrEmpty(duplicateMessage))
        {
                <text>
                        Swal.fire({
                            title: 'Duplicated Report',
                            text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(duplicateMessage)),
                            icon: 'warning',
                            showCancelButton: true,
                            showConfirmButton: false,
                            cancelButtonText: 'Go Back',
                            buttonsStyling: false,
                            customClass: {
                                popup: 'swal-glass-popup',
                                title: 'swal-glass-title',
                                htmlContainer: 'swal-glass-text',
                                confirmButton: 'swal-glass-confirm',
                                cancelButton: 'swal-glass-cancel'
                            }
                        });
                </text>
        }

        // Toggle Logic for Contact Method
        var phoneRadio = document.getElementById('choicePhone');
        var emailRadio = document.getElementById('choiceEmail');
        var phoneContainer = document.getElementById('phoneInputContainer');
        var emailContainer = document.getElementById('emailInputContainer');
        var phoneInput = document.getElementById('ContactPhone');
        var emailInput = document.getElementById('ContactEmail');

        if (phoneRadio && emailRadio) {
            function updateContactUI() {
                if (phoneRadio.checked) {
                    phoneContainer.style.display = 'flex';
                    emailContainer.style.display = 'none';
                    emailInput.value = ''; // Clear email if they switch to phone
                } else {
                    phoneContainer.style.display = 'none';
                    emailContainer.style.display = 'flex';
                    phoneInput.value = ''; // Clear phone if they switch to email
                }
            }

            phoneRadio.addEventListener('change', updateContactUI);
            emailRadio.addEventListener('change', updateContactUI);
        }

        // Submission & Validation
        var form = document.getElementById('reportItemForm');
        if (form) {
            form.addEventListener('submit', function (e) {
                e.preventDefault();

                // Validate the selected contact method
                var selectedChoice = document.querySelector('input[name="contactChoice"]:checked').value;
                var phone = phoneInput ? phoneInput.value.trim() : '';
                var email = emailInput ? emailInput.value.trim() : '';

                var isInvalid = false;
                var errorMessage = "";

                if (selectedChoice === 'phone' && !phone) {
                    isInvalid = true;
                    errorMessage = "Please enter your phone number.";
                } else if (selectedChoice === 'email' && !email) {
                    isInvalid = true;
                    errorMessage = "Please enter your email address.";
                }

                if (isInvalid) {
                    Swal.fire({
                        title: 'Contact Info Missing',
                        text: errorMessage,
                        icon: 'warning',
                        buttonsStyling: false,
                        customClass: {
                            popup: 'swal-glass-popup',
                            title: 'swal-glass-title',
                            htmlContainer: 'swal-glass-text',
                            confirmButton: 'swal-glass-confirm'
                        }
                    });
                    return; // Stop submission
                }

                // If valid, show confirmation
                Swal.fire({
                    title: 'Report this item?',
                    text: "Are you sure all the details and photos are correct?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, submit it!',
                    cancelButtonText: 'Go back',
                    buttonsStyling: false,
                    reverseButtons: true,
                    customClass: {
                        popup: 'swal-glass-popup',
                        title: 'swal-glass-title',
                        htmlContainer: 'swal-glass-text',
                        confirmButton: 'swal-glass-confirm',
                        cancelButton: 'swal-glass-cancel'
                    }
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });
        } else {
            console.warn('reportItemForm not found');
        }

        // Success Message
        @if (!string.IsNullOrEmpty(successMessage))
        {
                <text>
                        Swal.fire({
                            title: 'Success!',
                            text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMessage)),
                            icon: 'success',
                            confirmButtonText: 'Great!',
                            buttonsStyling: false,
                            customClass: {
                                popup: 'swal-glass-popup',
                                title: 'swal-glass-title',
                                htmlContainer: 'swal-glass-text',
                                confirmButton: 'swal-glass-confirm'
                            }
                        });
                </text>
        }
    });
</script>