@model EjustRecoveryHub.Models.ItemModel

@{
    ViewData["Title"] = "Item Details";

    var egyptTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Egypt Standard Time");
    var localTime = TimeZoneInfo.ConvertTimeFromUtc(Model.DateReported, egyptTimeZone);
}

<head>
    <title>Item Details</title>
</head>

<div class="glass-container details-wrapper d-flex align-items-center justify-content-center">
    <main class="main-content details-main">

        <a asp-controller="Items" asp-action="LostItems" class="back-link mb-4">
            <i class="fa-solid fa-arrow-left me-2"></i> Back to Search
        </a>

        <div class="custom-search-form form-stacked details-card-custom">

            <div class="details-image-wrapper d-flex align-items-center justify-content-center">
                @if (!string.IsNullOrEmpty(Model.PhotoPath))
                {
                    <img src="@Model.PhotoPath" alt="Item Photo" class="details-image" />
                }
                else
                {
                    <div class="details-no-image text-center">
                        <i class="fa-solid fa-image details-no-image-icon mb-3"></i>
                        <p>No Photo Provided</p>
                    </div>
                }
            </div>

            <div class="details-body">

                <div class="d-flex align-items-center justify-content-between flex-wrap gap-4 mb-4">
                    <div>
                        <span class="card-badge badge-solid-primary mb-2 d-inline-block">Found Item #@Model.Id</span>
                        <h2 class="details-title m-0">

                            <!-- Switch on Type to access specific properties -->
                            @switch (Model)
                            {
                                case EjustRecoveryHub.Models.IdItem idCard:
                                    @idCard.IdName
                                    break;
                                case EjustRecoveryHub.Models.DeviceItem device:
                                    @($"{device.DeviceBrand} {device.DeviceModel}")
                                    break;
                                case EjustRecoveryHub.Models.WalletItem wallet:
                                    @($"{wallet.WalletColor} Wallet")
                                    break;
                                case EjustRecoveryHub.Models.JewelryItem jewelry:
                                    @($"{jewelry.JewelryMaterial} {jewelry.JewelryType}")
                                    break;
                                case EjustRecoveryHub.Models.NotebookItem notebook:
                                    @($"{notebook.NotebookColor} Notebook")
                                    break;
                                default:
                                    @:Unknown Item
                                    break;
                            }
                        </h2>
                    </div>

                    <div class="card-badge badge-solid-primary position-static m-0 d-inline-block" style="transform: none;">
                        <span style="font-size: 0.9rem; font-weight: 500;">
                            <i class="fa-regular fa-clock me-1"></i> @localTime.ToString("dd MMM yyyy, hh:mm tt")
                        </span>
                    </div>
                </div>

                <div class="dynamic-group d-block mb-4">

                    <div class="search-input-group info-group-glass mb-3">
                        <i class="fa-solid fa-location-dot search-icon icon-secondary"></i>
                        <div class="info-content">
                            <small class="info-label d-block">Found At</small>
                            <strong class="info-value">@Model.LocationFound</strong>
                        </div>
                    </div>

                    <div class="search-input-group info-group-glass mb-3">
                        <i class="fa-solid fa-building-shield search-icon icon-primary"></i>
                        <div class="info-content">
                            <small class="info-label d-block">Currently Located At</small>
                            <strong class="info-value">@Model.ItemLocation</strong>
                        </div>
                    </div>

                </div>

                <div class="contact-action-box p-4 text-center">
                    <h4 class="contact-action-title mb-2">Is this yours?</h4>
                    <p class="contact-action-desc mb-4">Contact the finder directly to arrange a safe return.</p>

                    @Html.AntiForgeryToken()

                    <!-- The trigger button -->
                    <button type="button" id="revealContactBtn" class="btn-primary w-100 mt-4 d-block btn-reveal">
                        <i class="fa-solid fa-eye me-2"></i> Reveal Contact Info
                    </button>

                    <script>
                                            document.addEventListener('DOMContentLoaded', function () {
                                                var revealBtn = document.getElementById('revealContactBtn');

                                                if (revealBtn) {
                                                    revealBtn.addEventListener('click', function () {

                                                        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                                                        // 1. Show a loading state
                                                        var originalText = revealBtn.innerHTML;
                                                        revealBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> Loading...';
                                                        revealBtn.disabled = true;

                                                        // 2. Fetch the data securely
                                                        fetch('@Url.Action("RevealContact", "Items")', {
                                                            method: 'POST',
                                                            headers: {
                                                                'Content-Type': 'application/x-www-form-urlencoded',
                                                                'RequestVerificationToken': token
                                                            },
                                                            body: 'id=' + @Model.Id
                                                        })
                                                        .then(response => response.json())
                                                        .then(data => {
                                                            // Restore the button
                                                            revealBtn.innerHTML = originalText;
                                                            revealBtn.disabled = false;

                                                            if (data.success) {

                                                                // 3. Start building the HTML
                                                                var contactButtonsHtml = `
                                                                    <p class="text-muted mb-4" style="font-size: 0.95rem;">
                                                                        Please be respectful when contacting the finder.
                                                                    </p>
                                                                    <div class="d-flex flex-column gap-3">
                                                                `;

                                                                // Add Phone & WhatsApp buttons ONLY if a phone number exists
                                                                if (data.phone) {
                                                                    var phone = data.phone;
                                                                    var waNumber = "+20" + phone.replace(/^0+/, '');

                                                                    contactButtonsHtml += `
                                                                        <a href="tel:${phone}" class="search-btn w-100 text-white btn-contact-call d-block">
                                                                            <i class="fa-solid fa-phone me-2"></i> Call ${phone}
                                                                        </a>
                                                                        <a href="https://wa.me/${waNumber}" target="_blank" class="search-btn w-100 text-white btn-contact-wa d-block">
                                                                            <i class="fa-brands fa-whatsapp me-2"></i> WhatsApp
                                                                        </a>
                                                                    `;
                                                                }

                                                                // Add Email button ONLY if an email exists
                                                                if (data.email) {
                                                                    var email = data.email;

                                                                                                            // Create a pre-filled subject line (URL encoded so spaces don't break the link)
                                            var subject = encodeURIComponent("Regarding your found item on E-JUST Recovery Hub");

                                            // The secret Gmail compose URL
                                            var gmailUrl = `https://mail.google.com/mail/?view=cm&fs=1&to=${email}&su=${subject}`;

                                            contactButtonsHtml += `
                                                <a href="${gmailUrl}" target="_blank" class="search-btn w-100 text-white d-block" style="background: #ea4335; border: none; text-decoration: none; padding: 0.8rem;">
                                                    <i class="fa-brands fa-google me-2"></i> Email via Gmail
                                                </a>
                                            `;
                                                                }

                                                                // Close the div container
                                                                contactButtonsHtml += `</div>`;

                                                                // 4. Fire the SweetAlert2 popup
                                                                Swal.fire({
                                                                    title: 'Contact Details',
                                                                    icon: 'info',
                                                                    html: contactButtonsHtml,
                                                                    showConfirmButton: false,
                                                                    showCloseButton: true,
                                                                    buttonsStyling: false,
                                                                    customClass: {
                                                                        popup: 'swal-glass-popup',
                                                                        title: 'swal-glass-title',
                                                                        htmlContainer: 'swal-glass-text',
                                                                        closeButton: 'swal-glass-close'
                                                                    }
                                                                });
                                                            } else {
                                                                // Handle failure
                                                                Swal.fire({
                                                                    title: 'Error',
                                                                    text: data.message,
                                                                    icon: 'error',
                                                                    customClass: { popup: 'swal-glass-popup' }
                                                                });
                                                            }
                                                        })
                                                        .catch(error => {
                                                            revealBtn.innerHTML = originalText;
                                                            revealBtn.disabled = false;
                                                            Swal.fire({
                                                                title: 'Connection Error',
                                                                text: 'Could not load contact info securely. Please check your network.',
                                                                icon: 'error',
                                                                customClass: { popup: 'swal-glass-popup' }
                                                            });
                                                        });
                                                    });
                                                }
                                            });
                    </script>
                </div>
            </div>
        </div>
    </main>
</div>