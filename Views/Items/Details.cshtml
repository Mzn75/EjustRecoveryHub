@model EjustRecoveryHub.Models.ItemModel

@{
    ViewData["Title"] = "Item Details";
}

<head>
    <title>Item Details</title>
</head>


<div class="glass-container" style="padding: 2rem 1rem; min-height: 85vh; display: flex; align-items: center; justify-content: center;">
    <main class="main-content" style="max-width: 800px; width: 100%;">

        <a asp-controller="Items" asp-action="LostItems" style="color: var(--primary); text-decoration: none; font-weight: 600; display: inline-block; margin-bottom: 1.5rem;">
            <i class="fa-solid fa-arrow-left me-2"></i> Back to Search
        </a>

        <div class="custom-search-form form-stacked" style="padding: 0; overflow: hidden; align-content:center;">

            <div style="background: rgba(0,0,0,0.03); width: 100%; height: 300px; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid rgba(255,255,255,0.5);">
                @if (!string.IsNullOrEmpty(Model.PhotoPath))
                {
                    <img src="@Model.PhotoPath" alt="Item Photo" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                }
                else
                {
                    <div style="text-align: center; color: #a0aab5;">
                        <i class="fa-solid fa-image" style="font-size: 4rem; margin-bottom: 1rem;"></i>
                        <p>No Photo Provided</p>
                    </div>
                }
            </div>

            <div style="padding: 2.5rem;">

                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                    <div>
                        <span class="card-badge" style="background: var(--primary); color: white; margin-bottom: 0.5rem; display: inline-block;">Found Item #@Model.Id</span>
                        <h2 style="color: var(--dark); margin: 0; font-size: 2.5rem; text-transform: capitalize;">

                            <!-- Switch on Type to access specific properties -->
                            @switch (Model)
                            {
                                case EjustRecoveryHub.Models.IdItem idCard:
                                    @idCard.IdName
                                    break;
                                case EjustRecoveryHub.Models.DeviceItem device:
                                    @($"{device.DeviceBrand} {device.DeviceModel}")
                                    break;
                                case EjustRecoveryHub.Models.WalletItem wallet:
                                    @($"{wallet.WalletColor} Wallet")
                                    break;
                                case EjustRecoveryHub.Models.JewelryItem jewelry:
                                    @($"{jewelry.JewelryMaterial} {jewelry.JewelryType}")
                                    break;
                                case EjustRecoveryHub.Models.NotebookItem notebook:
                                    @($"{notebook.NotebookColor} Notebook")
                                    break;
                                default:
                                    @:Unknown Item
                                    break;
                            }
                        </h2>
                    </div>
                </div>

                <div class="dynamic-group" style="display: block; margin-bottom: 2rem;">

                    <div class="search-input-group mb-3" style="background: rgba(255,255,255,0.6);">
                        <i class="fa-solid fa-location-dot search-icon" style="color: var(--secondary);"></i>
                        <div style="padding: 0.8rem 1rem;">
                            <small style="color: #7f8c8d; display: block; font-size: 0.85rem;">Found At</small>
                            <strong style="color: var(--dark);">@Model.LocationFound</strong>
                        </div>
                    </div>

                    <div class="search-input-group mb-3" style="background: rgba(255,255,255,0.6);">
                        <i class="fa-solid fa-building-shield search-icon" style="color: var(--primary);"></i>
                        <div style="padding: 0.8rem 1rem;">
                            <small style="color: #7f8c8d; display: block; font-size: 0.85rem;">Currently Located At</small>
                            <strong style="color: var(--dark);">@Model.ItemLocation</strong>
                        </div>
                    </div>

                </div>

                <div style="background: rgba(37, 211, 102, 0.1); border: 1px solid rgba(37, 211, 102, 0.3); border-radius: 12px; padding: 1.5rem; text-align: center;">
                    <h4 style="color: var(--dark); margin-bottom: 0.5rem;">Is this yours?</h4>
                    <p style="color: #7f8c8d; margin-bottom: 1.5rem;">Contact the finder directly to arrange a safe return.</p>

                    <!-- The trigger button -->
                    <button type="button" id="revealContactBtn" class="btn-primary w-100 mt-4" style="display: block; cursor: pointer; font-size: 1.1rem; padding: 0.9rem;">
                        <i class="fa-solid fa-eye me-2"></i> Reveal Contact Info
                    </button>

                    <script>
                                            document.addEventListener('DOMContentLoaded', function () {
                                                var revealBtn = document.getElementById('revealContactBtn');

                                                if (revealBtn) {
                                                    revealBtn.addEventListener('click', function () {

                                                        // 1. Show a loading state to the user so they know it's working
                                                        var originalText = revealBtn.innerHTML;
                                                        revealBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> Loading...';
                                                        revealBtn.disabled = true;

                                                        // 2. Make a secure POST request to the server to fetch the number
                                                        // Bots scraping GET requests will never trigger this.
                                                        fetch('@Url.Action("RevealContact", "Items")', {
                                                            method: 'POST',
                                                            headers: {
                                                                'Content-Type': 'application/x-www-form-urlencoded'
                                                            },
                                                            body: 'id=' + @Model.Id
                                                        })
                                                        .then(response => response.json())
                                                        .then(data => {
                                                            // Restore the button
                                                            revealBtn.innerHTML = originalText;
                                                            revealBtn.disabled = false;

                                                            if (data.success) {
                                                                var phone = data.phone;
                                                                // Format the number for WhatsApp (assuming Egypt +20)
                                                                var waNumber = "+20" + phone.replace(/^0+/, '');

                                                                // 3. Build the HTML dynamically now that we have the real data
                                                                var contactButtonsHtml = `
                                                                    <p class="text-muted mb-4" style="font-size: 0.95rem;">
                                                                        Please be respectful when contacting the finder.
                                                                    </p>
                                                                    <div class="d-flex flex-column gap-3">
                                                                        <a href="tel:${phone}" class="search-btn w-100 text-white" style="background: var(--dark); text-decoration: none; padding: 0.8rem;">
                                                                            <i class="fa-solid fa-phone me-2"></i> Call ${phone}
                                                                        </a>
                                                                        <a href="https://wa.me/${waNumber}" target="_blank" class="search-btn w-100 text-white" style="background: #25D366; text-decoration: none; padding: 0.8rem;">
                                                                            <i class="fa-brands fa-whatsapp me-2"></i> WhatsApp
                                                                        </a>
                                                                    </div>
                                                                `;

                                                                // 4. Fire the SweetAlert2 popup
                                                                Swal.fire({
                                                                    title: 'Contact Details',
                                                                    icon: 'info',
                                                                    html: contactButtonsHtml,
                                                                    showConfirmButton: false,
                                                                    showCloseButton: true,
                                                                    buttonsStyling: false,
                                                                    customClass: {
                                                                        popup: 'swal-glass-popup',
                                                                        title: 'swal-glass-title',
                                                                        htmlContainer: 'swal-glass-text',
                                                                        closeButton: 'swal-glass-close'
                                                                    }
                                                                });
                                                            } else {
                                                                // Handle failure (e.g., item deleted or no number)
                                                                Swal.fire({
                                                                    title: 'Error',
                                                                    text: data.message,
                                                                    icon: 'error',
                                                                    customClass: { popup: 'swal-glass-popup' }
                                                                });
                                                            }
                                                        })
                                                        .catch(error => {
                                                            revealBtn.innerHTML = originalText;
                                                            revealBtn.disabled = false;
                                                            Swal.fire({
                                                                title: 'Connection Error',
                                                                text: 'Could not load contact info securely. Please check your network.',
                                                                icon: 'error',
                                                                customClass: { popup: 'swal-glass-popup' }
                                                            });
                                                        });
                                                    });
                                                }
                                            });
                    </script>
                </div>
            </div>
        </div>
    </main>
</div>