@{
    ViewData["Title"] = "Dashboard";
}

<!-- Sidebar Button -->
<button class="mobile-menu-btn d-lg-none">
    <!-- Icon -->
    <i class="fas fa-bars"></i>
</button>

<!-- Main Div -->
<div class="glass-container">
    <main class="main-content">

        <!-- The Header Section -->
        <div class="content-header welcome-header-card bg-white rounded shadow-sm p-5 text-center position-relative mb-4">

            <!-- 1. The Faded Background Icon -->
            <i class="fa-solid fa-magnifying-glass faded-watermark-icon"></i>

            <!-- 2. The Content -->
            <div class="position-relative z-1">
                <h2 class="fw-bold text-dark">Welcome to E-JUST Lost & Found Hub</h2>
                <p class="text-muted">Find your lost items and report found items easily</p>
            </div>

        </div>

        <!-- Dashboard Elements -->
        <div class="elements-grid">

            <!--Lost Items Page-->
            <div class="element-card">
                <div class="card-header">
                    <!-- Image src by Razor -->
                    <img src="@Url.Content("~/img/lost.svg")" alt="Lost Items" class="card-image">
                    <div class="card-overlay">
                        <h3 class="card-title">I Lost an item</h3>
                    </div>
                    <span class="card-badge">Find your items</span>
                </div>
                <div class="card-content">
                    <p class="card-description">
                        Search for your lost items and connect with finders to recover them quickly and easily.
                    </p>
                    <div class="card-actions">
                        <!-- Navigate to Search Lost Items Page -->
                        <a href="@Url.Action("LostItems", "Items")" class="btn-primary">
                            <i class="fas fa-search me-2"></i>
                            Search Lost Items
                        </a>
                    </div>
                </div>
            </div>

            <!--Found Items Page-->
            <div class="element-card">
                <div class="card-header">
                    <!-- Image src by Razor -->
                    <img src="@Url.Content("~/img/found.svg")" alt="Found Items" class="card-image">
                    <div class="card-overlay">
                        <h3 class="card-title">I Found an item</h3>
                    </div>
                    <span class="card-badge">Report items</span>
                </div>
                <div class="card-content">
                    <p class="card-description">
                        Report found items and help others recover their lost belongings.
                    </p>
                    <div class="card-actions">
                        <!-- Navigate to Report Found Items Page -->
                        <a href="@Url.Action("FoundItems", "Items")" class="btn-primary">
                            <i class="fa-solid fa-box-open me-2"></i>
                            Report Found Item
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>
